services:
  timetable:
    build: .
    restart: unless-stopped
    environment:
      API_KEY: ""
      DUALIS_USERNAME: "XXXXXX@hb.dhbw-stuttgart.de"
      DUALIS_PASSWORD: ""
      PORT: "3000"
      WEEKS_AHEAD: "2"
      CALENDAR_NAME: "Dualis Timetable"
      UID_DOMAIN: "schedule-sync.local"
      TIMEZONE: "Europe/Berlin"
      CACHE_TTL_SECONDS: "3600"
